{
  "name": "@canvas/app",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "description": "The canvas app: the live React renderer over the core + interaction engines. File-backed cards (a real folder's files as cards, updated live on disk change), runtime-loaded card-type templates, and the agent-sessions work — create/open/delete Claude Code sessions on an infinite canvas. A Node dev-server middleware (vite-fs-plugin.ts) serves the file tree + a chokidar watch stream; the board persists to IndexedDB behind core's Persistence seam.",
  "scripts": {
    "dev": "node dev-supervisor.js",
    "dev:bare": "vite",
    "dev:local": "CANVAS_SESSION_HOST=0 vite",
    "dev:restart-server": "node dev-supervisor.js restart-server",
    "dev:restart-jupyter": "node dev-supervisor.js restart-jupyter",
    "dev:stop": "node dev-supervisor.js stop",
    "dev:status": "node dev-supervisor.js status",
    "session-host": "node session-host.js",
    "session-host:stop": "node session-host.js --stop",
    "jupyter-host:stop": "node jupyter-host.js --stop",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test --test-concurrency=4 test/*.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "chokidar": "^4.0.3",
    "jsdom": "^29.1.1",
    "lit-html": "^3.3.3",
    "typescript": "^5.6.0",
    "vite": "^7.3.5",
    "ws": "^8.21.0"
  }
}
