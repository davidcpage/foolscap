#!/usr/bin/env bash
# canvas — a thin, allow-listable wrapper over the foolscap agent bus for SESSION-LIFECYCLE verbs.
#
# Why this exists: spawning a session is a POST to /api/session/spawn via curl, and the auto-mode
# permission classifier gates that as "creating an agent". Allowing `Bash(curl:*)` wholesale would be far
# too broad. Wrapping the gated verbs here lets the spawn path baseline-allow exactly `Bash(scripts/canvas
# ...)` (see BASELINE_ALLOWED_TOOLS in app/vite-fs-plugin.ts) — auditable, and every session gets legible
# verbs instead of raw curl. Per the session permission model, this is a UNIFORM baseline capability for
# every session, not a role permission.
#
# Thread verbs (msg/inbox/intent/pin/join/leave) are ALSO wrapped here now, so board messaging goes
# through the allow-listed path and bypasses the auto-mode permission classifier — raw curl to
# /api/thread/* otherwise gets gated/prompted, and stalls entirely when the classifier model is
# unavailable. (ask/reply/invite stay raw curl for now — add them here if the friction bites.)
#
# NOTE: a wrapper-spawned (like a curl-spawned) session leaves NO canvas card. To make it a thread
# member, the spawner must still addNode {id:"node:live:<sid>",type:"session",title:"<sid>"} + a
# member:open edge over /api/command (see CLAUDE.md "Driving sessions headlessly") — or just pass
# --thread and let the server do all of it.
set -euo pipefail

BOARD="${CANVAS_BOARD:-foolscap-a9921027}"
SERVER="${CANVAS_SERVER:-http://127.0.0.1:5173}"
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)" # repo root (this script lives in scripts/)

usage() {
  cat <<USAGE
canvas — session/coordination verbs over the agent bus
  scripts/canvas spawn [--thread THREAD] [--role ROLE] [--card] [--prompt TEXT] [--board ID]
                       [--worktree [--base REF] [--worktree-key KEY]]
        spawn a new session; prints {"id":...,"carded":bool}. With --thread the SERVER cards it, joins
        it, positions the card next to the thread, and onboards it to AWAIT its task on the thread —
        then POST the task as a thread message tagging it (do NOT put the task in --prompt; --prompt is
        only a generic first turn). --role spawns under a role. --card = standalone card, no membership.
        (--channel is the pre-rename alias for --thread and keeps working.)
        --worktree runs the session in an ISOLATED git worktree (its own branch under .canvas/worktrees/)
        instead of the shared board root, so concurrent agents don't clobber each other. Needs --thread
        (the durable work-item key). --base sets the branch base (default HEAD). The worktree is keyed by
        WORK ITEM (role seat if --role, else the thread, or --worktree-key), so a RESPAWN re-attaches to
        the same tree/branch — never a fresh cut. Prints a "worktree":{path,branch,reused,linked} block.
  scripts/canvas worktree list <THREAD>                list a thread's work-item worktrees (key→path/branch)
  scripts/canvas worktree rm <THREAD> [--key KEY | --role ROLE] [--force] [--from ID]
        tear down a work-item's worktree on COMPLETION (not session exit). Guarded: skips+warns if the tree
        is dirty or the branch is unmerged unless --force. Key defaults to the thread (bare worker); pass
        --role for a role-seat worktree, or --key for an explicit key.
  scripts/canvas worktree merge <THREAD> [--key KEY | --role ROLE] [--base REF] [--no-verify] [--force] [--from ID]
        MERGE-ON-GREEN: green-gate the work-item's branch in its worktree (npm test + typecheck for the
        packages it touched, always incl. app), then git merge --no-ff into --base (default main) from the
        canonical checkout and tear the worktree down — one command. Refuses a dirty worktree, a dirty or
        wrong-branch canonical checkout, or a failing gate; aborts cleanly on a merge conflict. --no-verify
        skips the gate; --force forwards to teardown. Key/role resolve like `rm`.
  scripts/canvas input <sid> <text>                   send a turn to a live session's stdin (reads AS the human)
  scripts/canvas done <sid>                            mark a session done + terminate it
  scripts/canvas terminate <sid>                       kill a live session, free its slot

  scripts/canvas msg <thread> [TEXT] [--stdin|--text-file F] [--from ID] [--force]   post a thread message
        (from = your sid, default "human"). Put @tags in the text; long/multi-paragraph text is best piped
        via --stdin or --text-file so it never has to survive shell-escaping. --force bypasses the
        unread-@-mention guard. Allow-listed, so it bypasses the classifier that gates raw curl to /api/thread/*.
  scripts/canvas inbox --session <sid> [--bytes N] [--limit N]   read your unread thread messages (advances
        the read cursor); window a long tail with --bytes/--limit.
  scripts/canvas intent <thread> working|blocked:human|blocked:peer|done [--note TEXT] [--from ID]
        declare your work-intent on a thread (card-only, wakes no one).
  scripts/canvas pin <thread> <seq> [--unpin] [--from ID]     pin (or --unpin) a message as head context.
  scripts/canvas join <thread> [--from ID] [--history full|future]   join a thread; leave <thread> leaves it.
  scripts/canvas leave <thread> [--from ID]

  scripts/canvas anno list [PATH] [--all] [--json]     no PATH: board sweep (open/orphan counts per file);
        with PATH: that file's annotations, one scannable line each (status, id, author, quote, replies).
        Default hides resolved (--all shows them). Replaces the hand-rolled /api/annotations curls.
  scripts/canvas anno reply <PATH> <ID> [TEXT] [--stdin|--text-file F] [--from ID]
        reply to one annotation. Pass long/multi-paragraph text via --stdin or --text-file so it never
        has to survive shell-escaping. --from is the author (a session passes its sid; default "human").
  scripts/canvas anno batch <PATH> <replies.json> [--from ID]
        reply to many at once: replies.json is DATA — [{"id":..,"text":..}] or {"<id>":"<text>"} — so you
        author replies once as JSON (Write tool), not as an ad-hoc urllib script. One POST per entry.
  scripts/canvas anno resolve|reopen <PATH> <ID> [--by ID]
        flip resolved state. Resolve your OWN comments; leave someone else's open for them (the author
        owns resolution). NOTE: no reanchor verb — the server auto-re-anchors on read/write; a comment
        your edit MOVED fixes itself, and only a true orphan (quote gone) needs a fresh anchor via the API.
  scripts/canvas anno ask <PATH> --question "…" [--anchor-exact "…" | --anchor-file F] [--options "A|B|C"] [--blocking] [--from ID]
        raise an ANCHORED QUESTION on a doc span (docs/anchored-async-ask.md) — the durable, anchored
        replacement for the in-session AskUserQuestion block. Answered async, where the question lives.
        --options are multiple-choice labels (split on |); --blocking marks you as waiting. Prints id + orphaned.
  scripts/canvas anno answer <PATH> <ID> [--choice LABEL] [--text "…" | --stdin | --text-file F] [--by ID]
        answer a question (an option label and/or prose); flips it awaiting → answered.
  scripts/canvas anno suggest <PATH> (--anchor-exact "…"|--anchor-file F) (--replacement "…"|--replacement-file F) [--note "…"] [--from ID]
        propose a track-changes edit: replace the anchored span with the replacement, decided as a unit.
  scripts/canvas anno accept|reject <PATH> <ID> [--by ID]
        accept applies the replacement to the file's bytes + resolves; reject resolves, bytes untouched.
  scripts/canvas anno watch <PATH> [--role R] [--level all|mentions|paused] [--pause|--resume|--unwatch] [--by ID]
        watch a doc for comments (P1/W4) — bind a ROLE as a watcher at a notification level (the durable
        "who to wake when a comment lands"). --pause/--resume toggle without losing the level; --unwatch drops
        it. Role defaults to Coordinator. anno list shows watchers (👁 role:level) per doc.

  scripts/canvas job add <THREAD>|--doc PATH --instruction TEXT [--interval MS] [--role R] [--from ID] [--job-id ID]
        declare a STANDING JOB (R6/W6) on a thread marker — a periodic server-fired worker. Every --interval
        (ms; clamped up to a 60s floor) the server spawns a FRESH worker seeded with --instruction; a named
        --role fires into that role's seat, else a bare worker. Jobs survive their creator AND a restart (they
        live on the marker). Pass --job-id to update an existing job in place. Norm: a firing that finds
        nothing posts nothing ("skip days with nothing"). With --doc PATH the job lives on a DOC's marker
        instead (doc-jobs; one worker per doc, fired by the same tick).
  scripts/canvas job coordinator <THREAD> [--interval MS] [--from ID]
        THE AUTONOMY SWITCH — enable the Coordinator HEARTBEAT as a standing job on <THREAD>, built from the
        canonical spec (app/coordinator-heartbeat.js). Fires the Coordinator seat on its interval to sweep the
        board (nudged if live, respawned if dormant). Deliberate + human-gated; turn OFF via job list + job rm.
  scripts/canvas job list <THREAD>|--doc PATH          list a thread's (or doc's) standing jobs (id, role, interval, lastFired)
  scripts/canvas job rm <THREAD> <JOB_ID> | --doc PATH <JOB_ID> [--from ID]  remove a standing job

  scripts/canvas memory search <query> [--limit N] [--json] [--doctor]   ranked lexical search of the file-memory
        store (.canvas/memory/*.md). Ranks slug/filename > description: > body; prints web-search-shaped hits
        (slug + description + matching lines, most-relevant first) so you skim and open the promising files.
        Lexical only (semantic search is out of scope). The index (MEMORY.md) is a bounded MAP — this is how
        you find any fact NOT on it. Resolves the store from the canonical checkout, so it works from a worktree.
  scripts/canvas memory doctor                          hygiene check: flags memory files missing a description:
        frontmatter or that look non-atomic (large / many headings). Advisory; changes nothing.
env: CANVAS_BOARD (default ${BOARD}), CANVAS_SERVER (default ${SERVER})
USAGE
}

# JSON-encode a single string safely (handles quotes/newlines/unicode).
jstr() { python3 -c 'import json,sys; print(json.dumps(sys.argv[1]))' "$1"; }
post() { curl -sS -X POST "$1" -H 'Content-Type: application/json' -d "$2"; }
# percent-encode a thread id for the URL PATH (thread ids contain colons: node:thread:<hex>).
enc() { python3 -c 'import sys,urllib.parse;print(urllib.parse.quote(sys.argv[1],safe=""))' "$1"; }

# Resolve the file-memory store dir (.canvas/memory). Honors CANVAS_MEMORY_DIR; else prefers REPO_ROOT's
# .canvas/memory, else falls back to the CANONICAL checkout (parent of the git common dir) — because .canvas
# is the shadow-versioned board home that lives in the main checkout, NOT in a per-worktree tree. So a
# session running from an isolated worktree still finds the one shared memory store.
memory_dir() {
  if [ -n "${CANVAS_MEMORY_DIR:-}" ]; then echo "$CANVAS_MEMORY_DIR"; return; fi
  if [ -d "$REPO_ROOT/.canvas/memory" ]; then echo "$REPO_ROOT/.canvas/memory"; return; fi
  local gcd root
  gcd="$(git -C "$REPO_ROOT" rev-parse --path-format=absolute --git-common-dir 2>/dev/null || true)"
  if [ -n "$gcd" ]; then
    root="$(dirname "$gcd")" # <root>/.git → <root>
    if [ -d "$root/.canvas/memory" ]; then echo "$root/.canvas/memory"; return; fi
  fi
  echo "$REPO_ROOT/.canvas/memory" # default (may not exist; the helper reports it)
}

# ── doc-annotation verbs (docs/doc-annotations.md) ──────────────────────────────────────────────────
# Ergonomic replacements for the raw /api/annotations curl the review flow used to hand-roll (and the
# ad-hoc python scripts it wrote to escape multi-paragraph replies). The server now auto-re-anchors on
# read/write, so there is no manual reanchor verb here — a comment your edit moved fixes itself; only a
# true orphan (its quoted text gone) needs a fresh anchor, which stays a raw create via the API.
ANNO_URL() { echo "$SERVER/api/annotations?board=$BOARD"; }
# read TEXT from a positional arg, --stdin, or --text-file — the point is that a long, multi-paragraph
# reply never has to survive shell-escaping: pipe it or hand it a file.
anno_read_text() { # $1=positional-or-empty $2=stdin-flag $3=text-file-or-empty
  if [ -n "$2" ]; then cat; elif [ -n "$3" ]; then cat "$3"; else printf '%s' "$1"; fi
}
anno_list() {
  local path="" all="" json=""
  while [ $# -gt 0 ]; do case "$1" in
    --all) all=1; shift ;; --json) json=1; shift ;; --board) BOARD="${2:-}"; shift 2 ;;
    --*) echo "anno list: unknown flag '$1'" >&2; exit 2 ;;
    *) path="$1"; shift ;;
  esac; done
  local url; url="$(ANNO_URL)"
  [ -n "$path" ] && url="$url&path=$(python3 -c 'import urllib.parse,sys;print(urllib.parse.quote(sys.argv[1]))' "$path")"
  if [ -n "$json" ]; then curl -sS "$url"; echo; return; fi
  # Pass the response as an argv, not a pipe: `python3 - <<PY` already claims stdin for the heredoc
  # script, so a `curl | python3 -` would feed the JSON into the same fd and lose it.
  local resp; resp="$(curl -sS "$url")"
  python3 - "$path" "$all" "$resp" <<'PY'
import json, sys
path, allf = sys.argv[1], bool(sys.argv[2])
d = json.loads(sys.argv[3])
if not path:  # the board sweep — questions awaiting a HUMAN float to the top (docs/anchored-async-ask.md §6)
    files = d.get("files", [])
    if not files: print("no annotations on this board"); sys.exit()
    for f in sorted(files, key=lambda f: (-f.get("awaiting", 0), -f["orphaned"], -f["open"], f["path"])):
        extra = ""
        if f.get("awaiting"): extra += f"  {f['awaiting']} awaiting"
        if f.get("answered"): extra += f"  {f['answered']} answered"
        # "what's watched" (P1/W4): the watchers arming this doc, role+level, paused ones parenthesised.
        for w in f.get("watchers", []):
            lvl = w.get("level", "all")
            extra += f"  👁 {w.get('role','?')}:{lvl}" + ("(paused)" if w.get("state") == "paused" else "")
        print(f"{f['open']:>3} open  {f['orphaned']:>2} orphan  {f['total']:>3} total   {f['path']}{extra}")
    sys.exit()
watchers = d.get("watchers", [])
if watchers:
    print("watchers: " + ", ".join(
        f"{w.get('role','?')}:{w.get('level','all')}" + ("(paused)" if w.get("state") == "paused" else "")
        for w in watchers))
ann = d.get("annotations", [])
op = [a for a in ann if not a["resolved"]]
orph = [a for a in op if a["orphaned"]]
nq = sum(1 for a in ann if a.get("kind") == "question")
head = f"{path} — {len(op)} open, {len(orph)} orphaned"
if nq: head += f", {nq} question(s)"
print(head + f" (of {len(ann)} total)")
for a in ann:
    if a["resolved"] and not allf: continue
    if a["resolved"]:            st = "done  "
    elif a["orphaned"]:          st = "ORPHAN"
    elif a.get("kind") == "question": st = "Q-answ" if a.get("state") == "answered" else "Q-wait"
    elif a.get("kind") == "suggestion": st = "S-prop"
    else:                        st = "open  "
    q = (a["anchor"].get("exact", "") or "").replace("\n", " ")
    if len(q) > 52: q = q[:51] + "…"
    opts = a.get("options") or []
    if opts: q += "  {" + "|".join(o.get("label", "") for o in opts) + "}"
    if a.get("kind") == "suggestion":
        rep = (a.get("replacement", "") or "").replace("\n", " ")
        if len(rep) > 40: rep = rep[:39] + "…"
        q += f'  → "{rep}"'
    reps = a.get("replies", [])
    tail = ""
    if reps:
        r = reps[-1]; t = r["text"].replace("\n", " ")
        if r.get("choice"): t = (f"[{r['choice']}] " + t).strip()
        if len(t) > 46: t = t[:45] + "…"
        tail = f"   last[{r['from'][:8]}]: {t}"
    print(f"  {st}  {a['id']}  {a['author'][:8]:8}  \"{q}\"  ({len(reps)} repl){tail}")
PY
}
anno_reply() {
  local from="human" stdin="" tfile="" pos=()
  while [ $# -gt 0 ]; do case "$1" in
    --from) from="${2:-}"; shift 2 ;; --stdin) stdin=1; shift ;; --text-file) tfile="${2:-}"; shift 2 ;;
    --board) BOARD="${2:-}"; shift 2 ;;
    --*) echo "anno reply: unknown flag '$1'" >&2; exit 2 ;;
    *) pos+=("$1"); shift ;;
  esac; done
  local path="${pos[0]:-}" id="${pos[1]:-}" arg="${pos[2]:-}"
  if [ -z "$path" ] || [ -z "$id" ]; then
    echo "usage: canvas anno reply <path> <id> [TEXT | --stdin | --text-file F] [--from ID]" >&2; exit 2; fi
  local text; text="$(anno_read_text "$arg" "$stdin" "$tfile")"
  if [ -z "$text" ]; then echo "anno reply: empty text (pass TEXT, --stdin, or --text-file)" >&2; exit 2; fi
  local body; body=$(python3 - "$path" "$id" "$from" "$text" <<'PY'
import json, sys
print(json.dumps({"op": "reply", "path": sys.argv[1], "id": sys.argv[2], "from": sys.argv[3], "text": sys.argv[4]}))
PY
)
  post "$(ANNO_URL)" "$body"; echo
}
anno_batch() {
  local from="human" pos=()
  while [ $# -gt 0 ]; do case "$1" in
    --from) from="${2:-}"; shift 2 ;; --board) BOARD="${2:-}"; shift 2 ;;
    --*) echo "anno batch: unknown flag '$1'" >&2; exit 2 ;;
    *) pos+=("$1"); shift ;;
  esac; done
  local path="${pos[0]:-}" file="${pos[1]:-}"
  if [ -z "$path" ] || [ -z "$file" ]; then
    echo "usage: canvas anno batch <path> <replies.json> [--from ID]" >&2
    echo "  replies.json = [{\"id\":...,\"text\":...}] or {\"<id>\":\"<text>\"} — author replies once as DATA," >&2
    echo "  not as an ad-hoc script; one POST per entry." >&2; exit 2; fi
  python3 - "$SERVER" "$BOARD" "$path" "$from" "$file" <<'PY'
import json, sys, urllib.request
server, board, path, frm, file = sys.argv[1:6]
data = json.load(open(file))
items = data if isinstance(data, list) else [{"id": k, "text": v} for k, v in data.items()]
url = f"{server}/api/annotations?board={board}"
ok = fail = 0
for it in items:
    body = json.dumps({"op": "reply", "path": path, "id": it["id"],
                       "from": it.get("from", frm), "text": it["text"]}).encode()
    req = urllib.request.Request(url, data=body, headers={"Content-Type": "application/json"})
    try:
        urllib.request.urlopen(req); ok += 1; print(f"  ok   {it['id']}")
    except Exception as e:
        fail += 1; print(f"  FAIL {it['id']}: {e}")
print(f"replied {ok}, failed {fail}")
sys.exit(1 if fail else 0)
PY
}
# Raise an anchored QUESTION (docs/anchored-async-ask.md) — a create with kind:"question". The anchor is
# a quote (like a plain create): --anchor-exact "…" or --anchor-file F (a long quote from a file, no
# shell-escaping); optional --anchor-prefix/--anchor-suffix disambiguate a repeated quote. --options are
# multiple-choice labels split on |; --blocking marks the asker as waiting (W5 will wake it on the answer).
anno_ask() {
  local from="human" question="" exact="" afile="" prefix="" suffix="" options="" blocking="" pos=()
  while [ $# -gt 0 ]; do case "$1" in
    --from) from="${2:-}"; shift 2 ;; --question) question="${2:-}"; shift 2 ;;
    --anchor-exact) exact="${2:-}"; shift 2 ;; --anchor-file) afile="${2:-}"; shift 2 ;;
    --anchor-prefix) prefix="${2:-}"; shift 2 ;; --anchor-suffix) suffix="${2:-}"; shift 2 ;;
    --options) options="${2:-}"; shift 2 ;; --blocking) blocking=1; shift ;;
    --board) BOARD="${2:-}"; shift 2 ;;
    --*) echo "anno ask: unknown flag '$1'" >&2; exit 2 ;;
    *) pos+=("$1"); shift ;;
  esac; done
  local path="${pos[0]:-}"
  if [ -z "$path" ]; then
    echo "usage: canvas anno ask <path> --question \"…\" [--anchor-exact \"…\" | --anchor-file F] [--options \"A|B|C\"] [--blocking] [--from ID]" >&2; exit 2; fi
  [ -n "$afile" ] && exact="$(cat "$afile")"
  if [ -z "$question" ] || [ -z "$exact" ]; then
    echo "anno ask: --question and --anchor-exact (or --anchor-file) are required" >&2; exit 2; fi
  local body; body=$(python3 - "$path" "$from" "$question" "$exact" "$prefix" "$suffix" "$options" "$blocking" <<'PY'
import json, sys
path, frm, q, exact, prefix, suffix, opts, blocking = sys.argv[1:9]
anchor = {"exact": exact}
if prefix: anchor["prefix"] = prefix
if suffix: anchor["suffix"] = suffix
o = {"op": "create", "path": path, "author": frm, "kind": "question", "text": q, "anchor": anchor}
if opts: o["options"] = [{"label": s} for s in opts.split("|") if s]
if blocking: o["blocking"] = True
print(json.dumps(o))
PY
)
  post "$(ANNO_URL)" "$body"; echo
}
# Answer a question (docs/anchored-async-ask.md §4): an option label (--choice) and/or prose (--text /
# --stdin / --text-file — a long answer never has to survive shell-escaping). Flips awaiting → answered.
anno_answer() {
  local by="human" choice="" tflag="" stdin="" tfile="" pos=()
  while [ $# -gt 0 ]; do case "$1" in
    --by) by="${2:-}"; shift 2 ;; --choice) choice="${2:-}"; shift 2 ;;
    --text) tflag="${2:-}"; shift 2 ;; --stdin) stdin=1; shift ;; --text-file) tfile="${2:-}"; shift 2 ;;
    --board) BOARD="${2:-}"; shift 2 ;;
    --*) echo "anno answer: unknown flag '$1'" >&2; exit 2 ;;
    *) pos+=("$1"); shift ;;
  esac; done
  local path="${pos[0]:-}" id="${pos[1]:-}"
  if [ -z "$path" ] || [ -z "$id" ]; then
    echo "usage: canvas anno answer <path> <id> [--choice LABEL] [--text \"…\" | --stdin | --text-file F] [--by ID]" >&2; exit 2; fi
  local text; text="$(anno_read_text "$tflag" "$stdin" "$tfile")"
  if [ -z "$choice" ] && [ -z "$text" ]; then
    echo "anno answer: pass --choice and/or answer text (--text / --stdin / --text-file)" >&2; exit 2; fi
  local body; body=$(python3 - "$path" "$id" "$by" "$choice" "$text" <<'PY'
import json, sys
path, id, by, choice, text = sys.argv[1:6]
o = {"op": "answer", "path": path, "id": id, "by": by}
if choice: o["choice"] = choice
if text: o["text"] = text
print(json.dumps(o))
PY
)
  post "$(ANNO_URL)" "$body"; echo
}
# Propose a track-changes SUGGESTION (a create with kind:"suggestion") — replace the anchored span with
# --replacement text, accepted or rejected as a unit. The anchor is a quote like a plain create; the
# replacement rides --replacement "…" or --replacement-file F (a long body, no shell-escaping).
anno_suggest() {
  local from="human" exact="" afile="" prefix="" suffix="" replacement="" rfile="" note="" pos=()
  while [ $# -gt 0 ]; do case "$1" in
    --from) from="${2:-}"; shift 2 ;;
    --anchor-exact) exact="${2:-}"; shift 2 ;; --anchor-file) afile="${2:-}"; shift 2 ;;
    --anchor-prefix) prefix="${2:-}"; shift 2 ;; --anchor-suffix) suffix="${2:-}"; shift 2 ;;
    --replacement) replacement="${2:-}"; shift 2 ;; --replacement-file) rfile="${2:-}"; shift 2 ;;
    --note|--text) note="${2:-}"; shift 2 ;;
    --board) BOARD="${2:-}"; shift 2 ;;
    --*) echo "anno suggest: unknown flag '$1'" >&2; exit 2 ;;
    *) pos+=("$1"); shift ;;
  esac; done
  local path="${pos[0]:-}"
  if [ -z "$path" ]; then
    echo "usage: canvas anno suggest <path> (--anchor-exact \"…\" | --anchor-file F) (--replacement \"…\" | --replacement-file F) [--note \"…\"] [--from ID]" >&2; exit 2; fi
  [ -n "$afile" ] && exact="$(cat "$afile")"
  [ -n "$rfile" ] && replacement="$(cat "$rfile")"
  if [ -z "$exact" ]; then echo "anno suggest: --anchor-exact (or --anchor-file) is required" >&2; exit 2; fi
  # An empty replacement is a valid deletion proposal, so there's no non-empty check on it.
  local body; body=$(python3 - "$path" "$from" "$exact" "$prefix" "$suffix" "$replacement" "$note" <<'PY'
import json, sys
path, frm, exact, prefix, suffix, replacement, note = sys.argv[1:8]
anchor = {"exact": exact}
if prefix: anchor["prefix"] = prefix
if suffix: anchor["suffix"] = suffix
o = {"op": "create", "path": path, "author": frm, "kind": "suggestion",
     "text": note or "suggested edit", "anchor": anchor, "replacement": replacement}
print(json.dumps(o))
PY
)
  post "$(ANNO_URL)" "$body"; echo
}
# Decide a suggestion: accept (apply the replacement to the file's bytes + resolve) or reject (resolve,
# bytes untouched). Both are one-shot — a decided suggestion is refused.
anno_decide() { # $1 = accept|reject
  local op="$1"; shift
  local by="human" pos=()
  while [ $# -gt 0 ]; do case "$1" in
    --by) by="${2:-}"; shift 2 ;; --board) BOARD="${2:-}"; shift 2 ;;
    --*) echo "anno $op: unknown flag '$1'" >&2; exit 2 ;;
    *) pos+=("$1"); shift ;;
  esac; done
  local path="${pos[0]:-}" id="${pos[1]:-}"
  if [ -z "$path" ] || [ -z "$id" ]; then echo "usage: canvas anno $op <path> <id> [--by ID]" >&2; exit 2; fi
  post "$(ANNO_URL)" "{\"op\":\"$op\",\"path\":$(jstr "$path"),\"id\":$(jstr "$id"),\"by\":$(jstr "$by")}"; echo
}
# Watch a doc for comments (docs/anchored-async-ask.md §2, wakeable-substrate-plan W4 — P1). Binds a ROLE
# as a watcher on the doc at a notification LEVEL (all/mentions/paused), the durable "who to wake when a
# comment lands" — a seat, one surface up from a thread. --pause/--resume toggle it without losing the
# level; --unwatch drops it. Role defaults to Coordinator (the board's standing watcher). W4 is pull-mode
# plumbing: this records the seat + level; the auto-spawn on a qualifying comment is W5.
anno_watch() {
  local role="Coordinator" level="" op="watch" by="human" pos=()
  while [ $# -gt 0 ]; do case "$1" in
    --role) role="${2:-}"; shift 2 ;; --level) level="${2:-}"; shift 2 ;;
    --pause) op="pause"; shift ;; --resume) op="resume"; shift ;; --unwatch) op="unwatch"; shift ;;
    --by) by="${2:-}"; shift 2 ;; --board) BOARD="${2:-}"; shift 2 ;;
    --*) echo "anno watch: unknown flag '$1'" >&2; exit 2 ;;
    *) pos+=("$1"); shift ;;
  esac; done
  local path="${pos[0]:-}"
  if [ -z "$path" ]; then
    echo "usage: canvas anno watch <path> [--role R] [--level all|mentions|paused] [--pause|--resume|--unwatch] [--by ID]" >&2; exit 2; fi
  local body; body=$(python3 - "$path" "$op" "$role" "$level" "$by" <<'PY'
import json, sys
path, op, role, level, by = sys.argv[1:6]
o = {"op": op, "path": path, "role": role, "by": by}
if op == "watch" and level: o["level"] = level
print(json.dumps(o))
PY
)
  post "$(ANNO_URL)" "$body"; echo
}
anno_setstate() { # $1 = resolve|reopen
  local op="$1"; shift
  local by="human" pos=()
  while [ $# -gt 0 ]; do case "$1" in
    --by) by="${2:-}"; shift 2 ;; --board) BOARD="${2:-}"; shift 2 ;;
    --*) echo "anno $op: unknown flag '$1'" >&2; exit 2 ;;
    *) pos+=("$1"); shift ;;
  esac; done
  local path="${pos[0]:-}" id="${pos[1]:-}"
  if [ -z "$path" ] || [ -z "$id" ]; then echo "usage: canvas anno $op <path> <id> [--by ID]" >&2; exit 2; fi
  post "$(ANNO_URL)" "{\"op\":\"$op\",\"path\":$(jstr "$path"),\"id\":$(jstr "$id"),\"by\":$(jstr "$by")}"; echo
}
anno() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    list) anno_list "$@" ;;
    reply) anno_reply "$@" ;;
    batch) anno_batch "$@" ;;
    ask) anno_ask "$@" ;;
    answer) anno_answer "$@" ;;
    suggest) anno_suggest "$@" ;;
    accept|reject) anno_decide "$sub" "$@" ;;
    watch) anno_watch "$@" ;;
    resolve|reopen) anno_setstate "$sub" "$@" ;;
    ""|-h|--help|help) echo "canvas anno list|reply|batch|ask|answer|suggest|accept|reject|watch|resolve|reopen — see 'canvas' for details" >&2 ;;
    *) echo "anno: unknown subcommand '$sub' (list|reply|batch|ask|answer|suggest|accept|reject|watch|resolve|reopen)" >&2; exit 2 ;;
  esac
}

# ── standing-job verbs (R6, docs/wakeable-substrate-plan.md W6) ─────────────────────────────────────
# Manage periodic server-fired jobs on a THREAD marker. A job spawns a fresh worker every interval, seeded
# with an instruction; a named --role fires into that role's seat, else a bare worker. Jobs survive their
# creator AND a server restart (they live on the marker, not the session). The interval is clamped up to a
# 60s floor server-side. "skip days with nothing": a firing that finds nothing posts nothing and winds down.
job() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    add|set)
      local thread="" doc="" instruction="" interval="" role="" from="human" jobid=""
      while [ $# -gt 0 ]; do case "$1" in
        --instruction)          instruction="${2:-}"; shift 2 ;;
        --interval|--interval-ms) interval="${2:-}"; shift 2 ;;
        --role)                 role="${2:-}"; shift 2 ;;
        --from)                 from="${2:-}"; shift 2 ;;
        --job-id|--jobid)       jobid="${2:-}"; shift 2 ;;
        --doc)                  doc="${2:-}"; shift 2 ;;
        --board)                BOARD="${2:-}"; shift 2 ;;
        --*) echo "job add: unknown flag '$1'" >&2; exit 2 ;;
        *) thread="$1"; shift ;;
      esac; done
      [ -n "$instruction" ] || [ -n "$jobid" ] || { echo "job add: need --instruction TEXT" >&2; exit 2; }
      if [ -n "$doc" ]; then
        # A DOC standing job (doc-jobs.js) — rides the /api/annotations op surface, keyed by path.
        local body; body=$(python3 - "$from" "$doc" "$instruction" "$interval" "$role" "$jobid" <<'PY'
import json, sys
frm, doc, instr, interval, role, jobid = sys.argv[1:7]
o = {"op": "job", "path": doc, "by": frm}
if instr:    o["instruction"] = instr
if interval: o["intervalMs"] = int(float(interval))
if role:     o["role"] = role
if jobid:    o["jobId"] = jobid
print(json.dumps(o))
PY
)
        post "$(ANNO_URL)" "$body"; echo; return
      fi
      [ -n "$thread" ] || { echo "job add: need a <threadId> (or --doc PATH)" >&2; exit 2; }
      local body; body=$(python3 - "$from" "$instruction" "$interval" "$role" "$jobid" <<'PY'
import json, sys
frm, instr, interval, role, jobid = sys.argv[1:6]
o = {"from": frm, "instruction": instr}
if interval: o["intervalMs"] = int(float(interval))
if role:     o["role"] = role
if jobid:    o["jobId"] = jobid
print(json.dumps(o))
PY
)
      post "$SERVER/api/thread/$thread/job?board=$BOARD" "$body"; echo ;;
    coordinator|coord)
      # THE AUTONOMY SWITCH (wakeable-substrate-plan.md — wake-live loop-migration). Enable the Coordinator
      # heartbeat as a standing job on <THREAD>, built from the canonical spec (coordinator-heartbeat.js) so
      # the sweep instruction never drifts. This is a deliberate, human-gated act: it starts an auto-firing
      # Coordinator that wakes on its interval to sweep the board (nudged if live, respawned if dormant).
      # Remove it (turn autonomy OFF) with `job list <THREAD>` then `job rm <THREAD> <jobId>`.
      local thread="" interval="" from="human"
      while [ $# -gt 0 ]; do case "$1" in
        --interval|--interval-ms) interval="${2:-}"; shift 2 ;;
        --from) from="${2:-}"; shift 2 ;;
        --board) BOARD="${2:-}"; shift 2 ;;
        --*) echo "job coordinator: unknown flag '$1'" >&2; exit 2 ;;
        *) thread="$1"; shift ;;
      esac; done
      [ -n "$thread" ] || { echo "job coordinator: need a <threadId> (the Coordinator's thread)" >&2; exit 2; }
      local body; body=$(CH_ROOT="$REPO_ROOT" CH_FROM="$from" CH_INTERVAL="$interval" node --input-type=module <<'PY'
const { coordinatorHeartbeatJobSpec } = await import(`${process.env.CH_ROOT}/app/coordinator-heartbeat.js`);
const interval = process.env.CH_INTERVAL;
const spec = coordinatorHeartbeatJobSpec(interval ? { intervalMs: Number(interval) } : {});
process.stdout.write(JSON.stringify({ from: process.env.CH_FROM, ...spec }));
PY
) || { echo "job coordinator: failed to build the spec" >&2; exit 1; }
      post "$SERVER/api/thread/$thread/job?board=$BOARD" "$body"; echo ;;
    rm|remove|delete)
      local thread="" doc="" jobid="" from="human" pos=()
      while [ $# -gt 0 ]; do case "$1" in
        --from) from="${2:-}"; shift 2 ;; --doc) doc="${2:-}"; shift 2 ;; --board) BOARD="${2:-}"; shift 2 ;;
        --*) echo "job rm: unknown flag '$1'" >&2; exit 2 ;;
        *) pos+=("$1"); shift ;;
      esac; done
      if [ -n "$doc" ]; then
        jobid="${pos[0]:-}"
        [ -n "$jobid" ] || { echo "job rm: need <jobId> (with --doc PATH)" >&2; exit 2; }
        post "$(ANNO_URL)" "{\"op\":\"unjob\",\"path\":$(jstr "$doc"),\"jobId\":$(jstr "$jobid"),\"by\":$(jstr "$from")}"; echo; return
      fi
      thread="${pos[0]:-}"; jobid="${pos[1]:-}"
      { [ -n "$thread" ] && [ -n "$jobid" ]; } || { echo "job rm: need <threadId> <jobId> (or --doc PATH <jobId>)" >&2; exit 2; }
      post "$SERVER/api/thread/$thread/job?board=$BOARD" "{\"from\":$(jstr "$from"),\"jobId\":$(jstr "$jobid"),\"remove\":true}"; echo ;;
    list|ls)
      local thread="" doc=""
      while [ $# -gt 0 ]; do case "$1" in
        --doc) doc="${2:-}"; shift 2 ;; --board) BOARD="${2:-}"; shift 2 ;;
        --*) echo "job list: unknown flag '$1'" >&2; exit 2 ;;
        *) thread="$1"; shift ;;
      esac; done
      if [ -n "$doc" ]; then
        # The per-file annotations read carries the doc's `jobs`; slice them out.
        local enc; enc=$(python3 -c 'import sys,urllib.parse;print(urllib.parse.quote(sys.argv[1]))' "$doc")
        curl -sS "$SERVER/api/annotations?board=$BOARD&path=$enc" \
          | python3 -c 'import sys,json; print(json.dumps(json.load(sys.stdin).get("jobs",[]),indent=2))'; return
      fi
      [ -n "$thread" ] || { echo "job list: need a <threadId> (or --doc PATH)" >&2; exit 2; }
      curl -sS "$SERVER/api/thread/$thread/jobs?board=$BOARD"; echo ;;
    ""|-h|--help|help) echo "canvas job add|list|rm [--doc PATH] | coordinator <THREAD> — periodic server-fired jobs on a thread OR doc marker (see 'canvas' for details)" >&2 ;;
    *) echo "job: unknown subcommand '$sub' (add|list|rm)" >&2; exit 2 ;;
  esac
}

cmd="${1:-}"; shift || true
case "$cmd" in
  spawn)
    prompt=""; thread=""; role=""; card=""; worktree=""; base=""; wtkey=""
    while [ $# -gt 0 ]; do
      case "$1" in
        --prompt)       prompt="${2:-}"; shift 2 ;;
        --thread)       thread="${2:-}"; shift 2 ;;
        --channel)      thread="${2:-}"; shift 2 ;; # pre-rename alias
        --role)         role="${2:-}"; shift 2 ;;
        --card)         card="1"; shift ;;
        --worktree)     worktree="1"; shift ;;
        --base)         base="${2:-}"; shift 2 ;;
        --worktree-key) wtkey="${2:-}"; shift 2 ;;
        --board)        BOARD="${2:-}"; shift 2 ;;
        *) echo "spawn: unexpected arg '$1'" >&2; exit 2 ;;
      esac
    done
    body=$(python3 - "$prompt" "$thread" "$role" "$card" "$worktree" "$base" "$wtkey" <<'PY'
import json, sys
prompt, thread, role, card, worktree, base, wtkey = sys.argv[1:8]
o = {}
if prompt:   o["prompt"] = prompt
if thread:   o["thread"] = thread
if role:     o["roleId"] = role
if card:     o["card"] = True
if worktree: o["worktree"] = True
if base:     o["base"] = base
if wtkey:    o["worktreeKey"] = wtkey
print(json.dumps(o))
PY
)
    post "$SERVER/api/session/spawn?board=$BOARD" "$body"; echo ;;
  worktree)
    sub="${1:?usage: canvas worktree list|rm <thread> ...}"; shift
    case "$sub" in
      list)
        thread="${1:?usage: canvas worktree list <thread>}"
        curl -sS "$SERVER/api/thread/$(enc "$thread")/worktrees?board=$BOARD"; echo ;;
      rm)
        thread="${1:?usage: canvas worktree rm <thread> [--key K|--role R] [--force] [--from ID]}"; shift
        from="human"; key=""; role=""; force=""
        while [ $# -gt 0 ]; do
          case "$1" in
            --key)   key="${2:-}"; shift 2 ;;
            --role)  role="${2:-}"; shift 2 ;;
            --force) force="1"; shift ;;
            --from)  from="${2:-}"; shift 2 ;;
            *) echo "worktree rm: unexpected arg '$1'" >&2; exit 2 ;;
          esac
        done
        body=$(python3 - "$from" "$key" "$role" "$force" <<'PY'
import json, sys
frm, key, role, force = sys.argv[1:5]
o = {"from": frm, "op": "remove"}
if key:   o["key"] = key
if role:  o["roleId"] = role
if force: o["force"] = True
print(json.dumps(o))
PY
)
        post "$SERVER/api/thread/$(enc "$thread")/worktree?board=$BOARD" "$body"; echo ;;
      merge)
        thread="${1:?usage: canvas worktree merge <thread> [--key K|--role R] [--base REF] [--no-verify] [--force] [--from ID]}"; shift
        from="human"; key=""; role=""; base=""; noverify=""; force=""
        while [ $# -gt 0 ]; do
          case "$1" in
            --key)       key="${2:-}"; shift 2 ;;
            --role)      role="${2:-}"; shift 2 ;;
            --base)      base="${2:-}"; shift 2 ;;
            --no-verify) noverify="1"; shift ;;
            --force)     force="1"; shift ;;
            --from)      from="${2:-}"; shift 2 ;;
            *) echo "worktree merge: unexpected arg '$1'" >&2; exit 2 ;;
          esac
        done
        body=$(python3 - "$from" "$key" "$role" "$base" "$noverify" "$force" <<'PY'
import json, sys
frm, key, role, base, noverify, force = sys.argv[1:7]
o = {"from": frm, "op": "merge"}
if key:      o["key"] = key
if role:     o["roleId"] = role
if base:     o["base"] = base
if noverify: o["noVerify"] = True
if force:    o["force"] = True
print(json.dumps(o))
PY
)
        post "$SERVER/api/thread/$(enc "$thread")/worktree?board=$BOARD" "$body"; echo ;;
      *) echo "worktree: unknown subcommand '$sub' (list|rm|merge)" >&2; exit 2 ;;
    esac ;;
  input)
    sid="${1:?usage: canvas input <sid> <text>}"; text="${2:?usage: canvas input <sid> <text>}"
    post "$SERVER/api/session/$sid/input" "{\"text\":$(jstr "$text")}"; echo ;;
  done)
    sid="${1:?usage: canvas done <sid>}"
    post "$SERVER/api/session/$sid/done" "{}"; echo ;;
  terminate)
    sid="${1:?usage: canvas terminate <sid>}"
    post "$SERVER/api/session/$sid/terminate" "{}"; echo ;;
  msg|message)
    thread="${1:?usage: canvas msg <thread> [TEXT] [--stdin|--text-file F] [--from ID] [--force]}"; shift
    from="human"; force=""; stdin=""; tfile=""; textarg=""
    while [ $# -gt 0 ]; do case "$1" in
      --from) from="${2:-}"; shift 2 ;;
      --force) force=1; shift ;;
      --stdin) stdin=1; shift ;;
      --text-file) tfile="${2:-}"; shift 2 ;;
      --board) BOARD="${2:-}"; shift 2 ;;
      --*) echo "msg: unknown flag '$1'" >&2; exit 2 ;;
      *) textarg="$1"; shift ;;
    esac; done
    text="$(anno_read_text "$textarg" "$stdin" "$tfile")"
    [ -n "$text" ] || { echo "msg: empty text (pass TEXT, --stdin, or --text-file)" >&2; exit 2; }
    body=$(python3 - "$from" "$text" "$force" <<'PY'
import json, sys
frm, text, force = sys.argv[1:4]
o = {"from": frm, "text": text}
if force: o["force"] = True
print(json.dumps(o))
PY
)
    post "$SERVER/api/thread/$(enc "$thread")/message?board=$BOARD" "$body"; echo ;;
  inbox)
    session=""; qs=""
    while [ $# -gt 0 ]; do case "$1" in
      --session) session="${2:-}"; shift 2 ;;
      --bytes) qs="$qs&bytes=${2:-}"; shift 2 ;;
      --limit) qs="$qs&limit=${2:-}"; shift 2 ;;
      *) echo "inbox: unexpected arg '$1'" >&2; exit 2 ;;
    esac; done
    [ -n "$session" ] || { echo "usage: canvas inbox --session <sid> [--bytes N] [--limit N]" >&2; exit 2; }
    curl -sS "$SERVER/api/inbox?session=$session$qs"; echo ;;
  intent)
    thread="${1:?usage: canvas intent <thread> <intent> [--note TEXT] [--from ID]}"; shift
    intent="${1:?usage: canvas intent <thread> <intent> [--note TEXT] [--from ID]}"; shift
    case "$intent" in working|blocked:human|blocked:peer|done) ;;
      *) echo "intent: must be working|blocked:human|blocked:peer|done" >&2; exit 2 ;; esac
    from="human"; note=""
    while [ $# -gt 0 ]; do case "$1" in
      --note) note="${2:-}"; shift 2 ;;
      --from) from="${2:-}"; shift 2 ;;
      --board) BOARD="${2:-}"; shift 2 ;;
      *) echo "intent: unexpected arg '$1'" >&2; exit 2 ;;
    esac; done
    body=$(python3 - "$from" "$intent" "$note" <<'PY'
import json, sys
frm, intent, note = sys.argv[1:4]
o = {"from": frm, "intent": intent}
if note: o["note"] = note
print(json.dumps(o))
PY
)
    post "$SERVER/api/thread/$(enc "$thread")/intent?board=$BOARD" "$body"; echo ;;
  pin)
    thread="${1:?usage: canvas pin <thread> <seq> [--unpin] [--from ID]}"; shift
    seq="${1:?usage: canvas pin <thread> <seq> [--unpin] [--from ID]}"; shift
    from="human"; pinned="true"
    while [ $# -gt 0 ]; do case "$1" in
      --unpin) pinned="false"; shift ;;
      --from) from="${2:-}"; shift 2 ;;
      --board) BOARD="${2:-}"; shift 2 ;;
      *) echo "pin: unexpected arg '$1'" >&2; exit 2 ;;
    esac; done
    post "$SERVER/api/thread/$(enc "$thread")/pin?board=$BOARD" "{\"from\":$(jstr "$from"),\"seq\":$seq,\"pinned\":$pinned}"; echo ;;
  join)
    thread="${1:?usage: canvas join <thread> [--from ID] [--history full|future]}"; shift
    from="human"; history=""
    while [ $# -gt 0 ]; do case "$1" in
      --from) from="${2:-}"; shift 2 ;;
      --history) history="${2:-}"; shift 2 ;;
      --board) BOARD="${2:-}"; shift 2 ;;
      *) echo "join: unexpected arg '$1'" >&2; exit 2 ;;
    esac; done
    body=$(python3 - "$from" "$history" <<'PY'
import json, sys
frm, history = sys.argv[1:3]
o = {"from": frm}
if history: o["history"] = history
print(json.dumps(o))
PY
)
    post "$SERVER/api/thread/$(enc "$thread")/join?board=$BOARD" "$body"; echo ;;
  leave)
    thread="${1:?usage: canvas leave <thread> [--from ID]}"; shift
    from="human"
    while [ $# -gt 0 ]; do case "$1" in
      --from) from="${2:-}"; shift 2 ;;
      --board) BOARD="${2:-}"; shift 2 ;;
      *) echo "leave: unexpected arg '$1'" >&2; exit 2 ;;
    esac; done
    post "$SERVER/api/thread/$(enc "$thread")/leave?board=$BOARD" "{\"from\":$(jstr "$from")}"; echo ;;
  memory)
    sub="${1:-}"; shift || true
    case "$sub" in
      search)
        [ $# -gt 0 ] || { echo "usage: canvas memory search <query> [--limit N] [--json] [--doctor]" >&2; exit 2; }
        node "$REPO_ROOT/app/memory-search.js" search --dir "$(memory_dir)" "$@" ;;
      doctor)
        node "$REPO_ROOT/app/memory-search.js" doctor --dir "$(memory_dir)" "$@" ;;
      ""|-h|--help) echo "usage: canvas memory search <query> [--limit N] [--json] [--doctor] | memory doctor" >&2; exit 2 ;;
      *) echo "memory: unknown subcommand '$sub' (search|doctor)" >&2; exit 2 ;;
    esac ;;
  anno)
    anno "$@" ;;
  job)
    job "$@" ;;
  ""|-h|--help|help) usage ;;
  *) echo "unknown verb: $cmd" >&2; usage >&2; exit 2 ;;
esac
