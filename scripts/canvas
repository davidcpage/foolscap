#!/usr/bin/env bash
# canvas — a thin, allow-listable wrapper over the foolscap agent bus for SESSION-LIFECYCLE verbs.
#
# Why this exists: spawning a session is a POST to /api/session/spawn via curl, and the auto-mode
# permission classifier gates that as "creating an agent". Allowing `Bash(curl:*)` wholesale would be far
# too broad. Wrapping the gated verbs here lets the spawn path baseline-allow exactly `Bash(scripts/canvas
# ...)` (see BASELINE_ALLOWED_TOOLS in app/vite-fs-plugin.ts) — auditable, and every session gets legible
# verbs instead of raw curl. Per the session permission model, this is a UNIFORM baseline capability for
# every session, not a role permission.
#
# Thread verbs (message/join/invite/ask/intent) are NOT gated and stay plain curl per the collaboration
# brief — only the session-process verbs need this wrapper.
#
# NOTE: a wrapper-spawned (like a curl-spawned) session leaves NO canvas card. To make it a thread
# member, the spawner must still addNode {id:"node:live:<sid>",type:"session",title:"<sid>"} + a
# member:open edge over /api/command (see CLAUDE.md "Driving sessions headlessly") — or just pass
# --thread and let the server do all of it.
set -euo pipefail

BOARD="${CANVAS_BOARD:-foolscap-a9921027}"
SERVER="${CANVAS_SERVER:-http://127.0.0.1:5173}"

usage() {
  cat <<USAGE
canvas — session/coordination verbs over the agent bus
  scripts/canvas spawn [--thread THREAD] [--role ROLE] [--card] [--prompt TEXT] [--board ID]
        spawn a new session; prints {"id":...,"carded":bool}. With --thread the SERVER cards it, joins
        it, positions the card next to the thread, and onboards it to AWAIT its task on the thread —
        then POST the task as a thread message tagging it (do NOT put the task in --prompt; --prompt is
        only a generic first turn). --role spawns under a role. --card = standalone card, no membership.
        (--channel is the pre-rename alias for --thread and keeps working.)
  scripts/canvas input <sid> <text>                   send a turn to a live session's stdin (reads AS the human)
  scripts/canvas done <sid>                            mark a session done + terminate it
  scripts/canvas terminate <sid>                       kill a live session, free its slot

  scripts/canvas anno list [PATH] [--all] [--json]     no PATH: board sweep (open/orphan counts per file);
        with PATH: that file's annotations, one scannable line each (status, id, author, quote, replies).
        Default hides resolved (--all shows them). Replaces the hand-rolled /api/annotations curls.
  scripts/canvas anno reply <PATH> <ID> [TEXT] [--stdin|--text-file F] [--from ID]
        reply to one annotation. Pass long/multi-paragraph text via --stdin or --text-file so it never
        has to survive shell-escaping. --from is the author (a session passes its sid; default "human").
  scripts/canvas anno batch <PATH> <replies.json> [--from ID]
        reply to many at once: replies.json is DATA — [{"id":..,"text":..}] or {"<id>":"<text>"} — so you
        author replies once as JSON (Write tool), not as an ad-hoc urllib script. One POST per entry.
  scripts/canvas anno resolve|reopen <PATH> <ID> [--by ID]
        flip resolved state. Resolve your OWN comments; leave someone else's open for them (the author
        owns resolution). NOTE: no reanchor verb — the server auto-re-anchors on read/write; a comment
        your edit MOVED fixes itself, and only a true orphan (quote gone) needs a fresh anchor via the API.
  scripts/canvas anno ask <PATH> --question "…" [--anchor-exact "…" | --anchor-file F] [--options "A|B|C"] [--blocking] [--from ID]
        raise an ANCHORED QUESTION on a doc span (docs/anchored-async-ask.md) — the durable, anchored
        replacement for the in-session AskUserQuestion block. Answered async, where the question lives.
        --options are multiple-choice labels (split on |); --blocking marks you as waiting. Prints id + orphaned.
  scripts/canvas anno answer <PATH> <ID> [--choice LABEL] [--text "…" | --stdin | --text-file F] [--by ID]
        answer a question (an option label and/or prose); flips it awaiting → answered.
  scripts/canvas anno watch <PATH> [--role R] [--level all|mentions|paused] [--pause|--resume|--unwatch] [--by ID]
        watch a doc for comments (P1/W4) — bind a ROLE as a watcher at a notification level (the durable
        "who to wake when a comment lands"). --pause/--resume toggle without losing the level; --unwatch drops
        it. Role defaults to Coordinator. anno list shows watchers (👁 role:level) per doc.

  scripts/canvas job add <THREAD> --instruction TEXT [--interval MS] [--role R] [--from ID] [--job-id ID]
        declare a STANDING JOB (R6/W6) on a thread marker — a periodic server-fired worker. Every --interval
        (ms; clamped up to a 60s floor) the server spawns a FRESH worker seeded with --instruction; a named
        --role fires into that role's seat, else a bare worker. Jobs survive their creator AND a restart (they
        live on the marker). Pass --job-id to update an existing job in place. Norm: a firing that finds
        nothing posts nothing ("skip days with nothing").
  scripts/canvas job list <THREAD>                     list a thread's standing jobs (id, role, interval, lastFired)
  scripts/canvas job rm <THREAD> <JOB_ID> [--from ID]  remove a standing job
env: CANVAS_BOARD (default ${BOARD}), CANVAS_SERVER (default ${SERVER})
USAGE
}

# JSON-encode a single string safely (handles quotes/newlines/unicode).
jstr() { python3 -c 'import json,sys; print(json.dumps(sys.argv[1]))' "$1"; }
post() { curl -sS -X POST "$1" -H 'Content-Type: application/json' -d "$2"; }

# ── doc-annotation verbs (docs/doc-annotations.md) ──────────────────────────────────────────────────
# Ergonomic replacements for the raw /api/annotations curl the review flow used to hand-roll (and the
# ad-hoc python scripts it wrote to escape multi-paragraph replies). The server now auto-re-anchors on
# read/write, so there is no manual reanchor verb here — a comment your edit moved fixes itself; only a
# true orphan (its quoted text gone) needs a fresh anchor, which stays a raw create via the API.
ANNO_URL() { echo "$SERVER/api/annotations?board=$BOARD"; }
# read TEXT from a positional arg, --stdin, or --text-file — the point is that a long, multi-paragraph
# reply never has to survive shell-escaping: pipe it or hand it a file.
anno_read_text() { # $1=positional-or-empty $2=stdin-flag $3=text-file-or-empty
  if [ -n "$2" ]; then cat; elif [ -n "$3" ]; then cat "$3"; else printf '%s' "$1"; fi
}
anno_list() {
  local path="" all="" json=""
  while [ $# -gt 0 ]; do case "$1" in
    --all) all=1; shift ;; --json) json=1; shift ;; --board) BOARD="${2:-}"; shift 2 ;;
    --*) echo "anno list: unknown flag '$1'" >&2; exit 2 ;;
    *) path="$1"; shift ;;
  esac; done
  local url; url="$(ANNO_URL)"
  [ -n "$path" ] && url="$url&path=$(python3 -c 'import urllib.parse,sys;print(urllib.parse.quote(sys.argv[1]))' "$path")"
  if [ -n "$json" ]; then curl -sS "$url"; echo; return; fi
  # Pass the response as an argv, not a pipe: `python3 - <<PY` already claims stdin for the heredoc
  # script, so a `curl | python3 -` would feed the JSON into the same fd and lose it.
  local resp; resp="$(curl -sS "$url")"
  python3 - "$path" "$all" "$resp" <<'PY'
import json, sys
path, allf = sys.argv[1], bool(sys.argv[2])
d = json.loads(sys.argv[3])
if not path:  # the board sweep — questions awaiting a HUMAN float to the top (docs/anchored-async-ask.md §6)
    files = d.get("files", [])
    if not files: print("no annotations on this board"); sys.exit()
    for f in sorted(files, key=lambda f: (-f.get("awaiting", 0), -f["orphaned"], -f["open"], f["path"])):
        extra = ""
        if f.get("awaiting"): extra += f"  {f['awaiting']} awaiting"
        if f.get("answered"): extra += f"  {f['answered']} answered"
        # "what's watched" (P1/W4): the watchers arming this doc, role+level, paused ones parenthesised.
        for w in f.get("watchers", []):
            lvl = w.get("level", "all")
            extra += f"  👁 {w.get('role','?')}:{lvl}" + ("(paused)" if w.get("state") == "paused" else "")
        print(f"{f['open']:>3} open  {f['orphaned']:>2} orphan  {f['total']:>3} total   {f['path']}{extra}")
    sys.exit()
watchers = d.get("watchers", [])
if watchers:
    print("watchers: " + ", ".join(
        f"{w.get('role','?')}:{w.get('level','all')}" + ("(paused)" if w.get("state") == "paused" else "")
        for w in watchers))
ann = d.get("annotations", [])
op = [a for a in ann if not a["resolved"]]
orph = [a for a in op if a["orphaned"]]
nq = sum(1 for a in ann if a.get("kind") == "question")
head = f"{path} — {len(op)} open, {len(orph)} orphaned"
if nq: head += f", {nq} question(s)"
print(head + f" (of {len(ann)} total)")
for a in ann:
    if a["resolved"] and not allf: continue
    if a["resolved"]:            st = "done  "
    elif a["orphaned"]:          st = "ORPHAN"
    elif a.get("kind") == "question": st = "Q-answ" if a.get("state") == "answered" else "Q-wait"
    else:                        st = "open  "
    q = (a["anchor"].get("exact", "") or "").replace("\n", " ")
    if len(q) > 52: q = q[:51] + "…"
    opts = a.get("options") or []
    if opts: q += "  {" + "|".join(o.get("label", "") for o in opts) + "}"
    reps = a.get("replies", [])
    tail = ""
    if reps:
        r = reps[-1]; t = r["text"].replace("\n", " ")
        if r.get("choice"): t = (f"[{r['choice']}] " + t).strip()
        if len(t) > 46: t = t[:45] + "…"
        tail = f"   last[{r['from'][:8]}]: {t}"
    print(f"  {st}  {a['id']}  {a['author'][:8]:8}  \"{q}\"  ({len(reps)} repl){tail}")
PY
}
anno_reply() {
  local from="human" stdin="" tfile="" pos=()
  while [ $# -gt 0 ]; do case "$1" in
    --from) from="${2:-}"; shift 2 ;; --stdin) stdin=1; shift ;; --text-file) tfile="${2:-}"; shift 2 ;;
    --board) BOARD="${2:-}"; shift 2 ;;
    --*) echo "anno reply: unknown flag '$1'" >&2; exit 2 ;;
    *) pos+=("$1"); shift ;;
  esac; done
  local path="${pos[0]:-}" id="${pos[1]:-}" arg="${pos[2]:-}"
  if [ -z "$path" ] || [ -z "$id" ]; then
    echo "usage: canvas anno reply <path> <id> [TEXT | --stdin | --text-file F] [--from ID]" >&2; exit 2; fi
  local text; text="$(anno_read_text "$arg" "$stdin" "$tfile")"
  if [ -z "$text" ]; then echo "anno reply: empty text (pass TEXT, --stdin, or --text-file)" >&2; exit 2; fi
  local body; body=$(python3 - "$path" "$id" "$from" "$text" <<'PY'
import json, sys
print(json.dumps({"op": "reply", "path": sys.argv[1], "id": sys.argv[2], "from": sys.argv[3], "text": sys.argv[4]}))
PY
)
  post "$(ANNO_URL)" "$body"; echo
}
anno_batch() {
  local from="human" pos=()
  while [ $# -gt 0 ]; do case "$1" in
    --from) from="${2:-}"; shift 2 ;; --board) BOARD="${2:-}"; shift 2 ;;
    --*) echo "anno batch: unknown flag '$1'" >&2; exit 2 ;;
    *) pos+=("$1"); shift ;;
  esac; done
  local path="${pos[0]:-}" file="${pos[1]:-}"
  if [ -z "$path" ] || [ -z "$file" ]; then
    echo "usage: canvas anno batch <path> <replies.json> [--from ID]" >&2
    echo "  replies.json = [{\"id\":...,\"text\":...}] or {\"<id>\":\"<text>\"} — author replies once as DATA," >&2
    echo "  not as an ad-hoc script; one POST per entry." >&2; exit 2; fi
  python3 - "$SERVER" "$BOARD" "$path" "$from" "$file" <<'PY'
import json, sys, urllib.request
server, board, path, frm, file = sys.argv[1:6]
data = json.load(open(file))
items = data if isinstance(data, list) else [{"id": k, "text": v} for k, v in data.items()]
url = f"{server}/api/annotations?board={board}"
ok = fail = 0
for it in items:
    body = json.dumps({"op": "reply", "path": path, "id": it["id"],
                       "from": it.get("from", frm), "text": it["text"]}).encode()
    req = urllib.request.Request(url, data=body, headers={"Content-Type": "application/json"})
    try:
        urllib.request.urlopen(req); ok += 1; print(f"  ok   {it['id']}")
    except Exception as e:
        fail += 1; print(f"  FAIL {it['id']}: {e}")
print(f"replied {ok}, failed {fail}")
sys.exit(1 if fail else 0)
PY
}
# Raise an anchored QUESTION (docs/anchored-async-ask.md) — a create with kind:"question". The anchor is
# a quote (like a plain create): --anchor-exact "…" or --anchor-file F (a long quote from a file, no
# shell-escaping); optional --anchor-prefix/--anchor-suffix disambiguate a repeated quote. --options are
# multiple-choice labels split on |; --blocking marks the asker as waiting (W5 will wake it on the answer).
anno_ask() {
  local from="human" question="" exact="" afile="" prefix="" suffix="" options="" blocking="" pos=()
  while [ $# -gt 0 ]; do case "$1" in
    --from) from="${2:-}"; shift 2 ;; --question) question="${2:-}"; shift 2 ;;
    --anchor-exact) exact="${2:-}"; shift 2 ;; --anchor-file) afile="${2:-}"; shift 2 ;;
    --anchor-prefix) prefix="${2:-}"; shift 2 ;; --anchor-suffix) suffix="${2:-}"; shift 2 ;;
    --options) options="${2:-}"; shift 2 ;; --blocking) blocking=1; shift ;;
    --board) BOARD="${2:-}"; shift 2 ;;
    --*) echo "anno ask: unknown flag '$1'" >&2; exit 2 ;;
    *) pos+=("$1"); shift ;;
  esac; done
  local path="${pos[0]:-}"
  if [ -z "$path" ]; then
    echo "usage: canvas anno ask <path> --question \"…\" [--anchor-exact \"…\" | --anchor-file F] [--options \"A|B|C\"] [--blocking] [--from ID]" >&2; exit 2; fi
  [ -n "$afile" ] && exact="$(cat "$afile")"
  if [ -z "$question" ] || [ -z "$exact" ]; then
    echo "anno ask: --question and --anchor-exact (or --anchor-file) are required" >&2; exit 2; fi
  local body; body=$(python3 - "$path" "$from" "$question" "$exact" "$prefix" "$suffix" "$options" "$blocking" <<'PY'
import json, sys
path, frm, q, exact, prefix, suffix, opts, blocking = sys.argv[1:9]
anchor = {"exact": exact}
if prefix: anchor["prefix"] = prefix
if suffix: anchor["suffix"] = suffix
o = {"op": "create", "path": path, "author": frm, "kind": "question", "text": q, "anchor": anchor}
if opts: o["options"] = [{"label": s} for s in opts.split("|") if s]
if blocking: o["blocking"] = True
print(json.dumps(o))
PY
)
  post "$(ANNO_URL)" "$body"; echo
}
# Answer a question (docs/anchored-async-ask.md §4): an option label (--choice) and/or prose (--text /
# --stdin / --text-file — a long answer never has to survive shell-escaping). Flips awaiting → answered.
anno_answer() {
  local by="human" choice="" tflag="" stdin="" tfile="" pos=()
  while [ $# -gt 0 ]; do case "$1" in
    --by) by="${2:-}"; shift 2 ;; --choice) choice="${2:-}"; shift 2 ;;
    --text) tflag="${2:-}"; shift 2 ;; --stdin) stdin=1; shift ;; --text-file) tfile="${2:-}"; shift 2 ;;
    --board) BOARD="${2:-}"; shift 2 ;;
    --*) echo "anno answer: unknown flag '$1'" >&2; exit 2 ;;
    *) pos+=("$1"); shift ;;
  esac; done
  local path="${pos[0]:-}" id="${pos[1]:-}"
  if [ -z "$path" ] || [ -z "$id" ]; then
    echo "usage: canvas anno answer <path> <id> [--choice LABEL] [--text \"…\" | --stdin | --text-file F] [--by ID]" >&2; exit 2; fi
  local text; text="$(anno_read_text "$tflag" "$stdin" "$tfile")"
  if [ -z "$choice" ] && [ -z "$text" ]; then
    echo "anno answer: pass --choice and/or answer text (--text / --stdin / --text-file)" >&2; exit 2; fi
  local body; body=$(python3 - "$path" "$id" "$by" "$choice" "$text" <<'PY'
import json, sys
path, id, by, choice, text = sys.argv[1:6]
o = {"op": "answer", "path": path, "id": id, "by": by}
if choice: o["choice"] = choice
if text: o["text"] = text
print(json.dumps(o))
PY
)
  post "$(ANNO_URL)" "$body"; echo
}
# Watch a doc for comments (docs/anchored-async-ask.md §2, wakeable-substrate-plan W4 — P1). Binds a ROLE
# as a watcher on the doc at a notification LEVEL (all/mentions/paused), the durable "who to wake when a
# comment lands" — a seat, one surface up from a thread. --pause/--resume toggle it without losing the
# level; --unwatch drops it. Role defaults to Coordinator (the board's standing watcher). W4 is pull-mode
# plumbing: this records the seat + level; the auto-spawn on a qualifying comment is W5.
anno_watch() {
  local role="Coordinator" level="" op="watch" by="human" pos=()
  while [ $# -gt 0 ]; do case "$1" in
    --role) role="${2:-}"; shift 2 ;; --level) level="${2:-}"; shift 2 ;;
    --pause) op="pause"; shift ;; --resume) op="resume"; shift ;; --unwatch) op="unwatch"; shift ;;
    --by) by="${2:-}"; shift 2 ;; --board) BOARD="${2:-}"; shift 2 ;;
    --*) echo "anno watch: unknown flag '$1'" >&2; exit 2 ;;
    *) pos+=("$1"); shift ;;
  esac; done
  local path="${pos[0]:-}"
  if [ -z "$path" ]; then
    echo "usage: canvas anno watch <path> [--role R] [--level all|mentions|paused] [--pause|--resume|--unwatch] [--by ID]" >&2; exit 2; fi
  local body; body=$(python3 - "$path" "$op" "$role" "$level" "$by" <<'PY'
import json, sys
path, op, role, level, by = sys.argv[1:6]
o = {"op": op, "path": path, "role": role, "by": by}
if op == "watch" and level: o["level"] = level
print(json.dumps(o))
PY
)
  post "$(ANNO_URL)" "$body"; echo
}
anno_setstate() { # $1 = resolve|reopen
  local op="$1"; shift
  local by="human" pos=()
  while [ $# -gt 0 ]; do case "$1" in
    --by) by="${2:-}"; shift 2 ;; --board) BOARD="${2:-}"; shift 2 ;;
    --*) echo "anno $op: unknown flag '$1'" >&2; exit 2 ;;
    *) pos+=("$1"); shift ;;
  esac; done
  local path="${pos[0]:-}" id="${pos[1]:-}"
  if [ -z "$path" ] || [ -z "$id" ]; then echo "usage: canvas anno $op <path> <id> [--by ID]" >&2; exit 2; fi
  post "$(ANNO_URL)" "{\"op\":\"$op\",\"path\":$(jstr "$path"),\"id\":$(jstr "$id"),\"by\":$(jstr "$by")}"; echo
}
anno() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    list) anno_list "$@" ;;
    reply) anno_reply "$@" ;;
    batch) anno_batch "$@" ;;
    ask) anno_ask "$@" ;;
    answer) anno_answer "$@" ;;
    watch) anno_watch "$@" ;;
    resolve|reopen) anno_setstate "$sub" "$@" ;;
    ""|-h|--help|help) echo "canvas anno list|reply|batch|ask|answer|watch|resolve|reopen — see 'canvas' for details" >&2 ;;
    *) echo "anno: unknown subcommand '$sub' (list|reply|batch|ask|answer|watch|resolve|reopen)" >&2; exit 2 ;;
  esac
}

# ── standing-job verbs (R6, docs/wakeable-substrate-plan.md W6) ─────────────────────────────────────
# Manage periodic server-fired jobs on a THREAD marker. A job spawns a fresh worker every interval, seeded
# with an instruction; a named --role fires into that role's seat, else a bare worker. Jobs survive their
# creator AND a server restart (they live on the marker, not the session). The interval is clamped up to a
# 60s floor server-side. "skip days with nothing": a firing that finds nothing posts nothing and winds down.
job() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    add|set)
      local thread="" instruction="" interval="" role="" from="human" jobid=""
      while [ $# -gt 0 ]; do case "$1" in
        --instruction)          instruction="${2:-}"; shift 2 ;;
        --interval|--interval-ms) interval="${2:-}"; shift 2 ;;
        --role)                 role="${2:-}"; shift 2 ;;
        --from)                 from="${2:-}"; shift 2 ;;
        --job-id|--jobid)       jobid="${2:-}"; shift 2 ;;
        --board)                BOARD="${2:-}"; shift 2 ;;
        --*) echo "job add: unknown flag '$1'" >&2; exit 2 ;;
        *) thread="$1"; shift ;;
      esac; done
      [ -n "$thread" ] || { echo "job add: need a <threadId>" >&2; exit 2; }
      [ -n "$instruction" ] || { echo "job add: need --instruction TEXT" >&2; exit 2; }
      local body; body=$(python3 - "$from" "$instruction" "$interval" "$role" "$jobid" <<'PY'
import json, sys
frm, instr, interval, role, jobid = sys.argv[1:6]
o = {"from": frm, "instruction": instr}
if interval: o["intervalMs"] = int(float(interval))
if role:     o["role"] = role
if jobid:    o["jobId"] = jobid
print(json.dumps(o))
PY
)
      post "$SERVER/api/thread/$thread/job?board=$BOARD" "$body"; echo ;;
    rm|remove|delete)
      local thread="${1:-}" jobid="${2:-}" from="human"
      shift 2 2>/dev/null || true
      while [ $# -gt 0 ]; do case "$1" in --from) from="${2:-}"; shift 2 ;; --board) BOARD="${2:-}"; shift 2 ;; *) shift ;; esac; done
      { [ -n "$thread" ] && [ -n "$jobid" ]; } || { echo "job rm: need <threadId> <jobId>" >&2; exit 2; }
      post "$SERVER/api/thread/$thread/job?board=$BOARD" "{\"from\":$(jstr "$from"),\"jobId\":$(jstr "$jobid"),\"remove\":true}"; echo ;;
    list|ls)
      local thread="${1:-}"
      shift || true
      while [ $# -gt 0 ]; do case "$1" in --board) BOARD="${2:-}"; shift 2 ;; *) shift ;; esac; done
      [ -n "$thread" ] || { echo "job list: need a <threadId>" >&2; exit 2; }
      curl -sS "$SERVER/api/thread/$thread/jobs?board=$BOARD"; echo ;;
    ""|-h|--help|help) echo "canvas job add|list|rm — periodic server-fired jobs on a thread marker (see 'canvas' for details)" >&2 ;;
    *) echo "job: unknown subcommand '$sub' (add|list|rm)" >&2; exit 2 ;;
  esac
}

cmd="${1:-}"; shift || true
case "$cmd" in
  spawn)
    prompt=""; thread=""; role=""; card=""
    while [ $# -gt 0 ]; do
      case "$1" in
        --prompt)  prompt="${2:-}"; shift 2 ;;
        --thread)  thread="${2:-}"; shift 2 ;;
        --channel) thread="${2:-}"; shift 2 ;; # pre-rename alias
        --role)    role="${2:-}"; shift 2 ;;
        --card)    card="1"; shift ;;
        --board)   BOARD="${2:-}"; shift 2 ;;
        *) echo "spawn: unexpected arg '$1'" >&2; exit 2 ;;
      esac
    done
    body=$(python3 - "$prompt" "$thread" "$role" "$card" <<'PY'
import json, sys
prompt, thread, role, card = sys.argv[1:5]
o = {}
if prompt: o["prompt"] = prompt
if thread: o["thread"] = thread
if role:   o["roleId"] = role
if card:   o["card"] = True
print(json.dumps(o))
PY
)
    post "$SERVER/api/session/spawn?board=$BOARD" "$body"; echo ;;
  input)
    sid="${1:?usage: canvas input <sid> <text>}"; text="${2:?usage: canvas input <sid> <text>}"
    post "$SERVER/api/session/$sid/input" "{\"text\":$(jstr "$text")}"; echo ;;
  done)
    sid="${1:?usage: canvas done <sid>}"
    post "$SERVER/api/session/$sid/done" "{}"; echo ;;
  terminate)
    sid="${1:?usage: canvas terminate <sid>}"
    post "$SERVER/api/session/$sid/terminate" "{}"; echo ;;
  anno)
    anno "$@" ;;
  job)
    job "$@" ;;
  ""|-h|--help|help) usage ;;
  *) echo "unknown verb: $cmd" >&2; usage >&2; exit 2 ;;
esac
